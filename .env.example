# Copy to .env.local for local development, or set these as environment
# variables in Dokploy for each deployment. All values below are safe local
# defaults — override them per environment.

# Internal URL of the FastAPI backend, reachable from the Next.js server.
# Local: http://localhost:8000/api/v1
# Docker/Dokploy: http://<backend-service-name>:8000/api/v1
BACKEND_INTERNAL_URL=http://localhost:8000/api/v1

# Internal URL of this Next.js instance, used for server-side self-calls
# (RSC and Route Handlers need an absolute URL).
# Local: http://localhost:3000
# Docker/Dokploy: http://<frontend-service-name>:3000
NEXTJS_INTERNAL_URL=http://localhost:3000
