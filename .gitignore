# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Keep the template so deployments (Dokploy) know which vars to set
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# === Proyecto (fusionado del .gitignore raíz) ===
# Infra del agente de IA (local, regenerable — no compartir)
.claude/
.atl/

# Secretos
secrets/

# Sistema operativo
Thumbs.db
desktop.ini

# Editores
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*~

# Logs y temporales
*.log
.cache/
tmp/

# Agent guide and internal docs — not published to the company repository
CLAUDE.md
/docs/
